        final textBack = currentCard.cardData.firstWhere((c) => c.groupId == headerBack.groupId).content.text;
        🔹 Luồng B: Tạo danh sách tối đa 6 Bong Bóng mép phảiDuyệt mảng personalizedHeaders, loại bỏ 2 phần tử đầu (A và B), lấy tối đa 6 phần tử tiếp theo để dựng Widget cột bong bóng:Dartfinal bubbleHeaders = response.personalizedHeaders
            .where((h) => h.personalizedRank != 'A' && h.personalizedRank != 'B')
            .take(6) // Khống chế cứng giới hạn tối đa 6 bong bóng phòng rách lưới UI
            .toList();
