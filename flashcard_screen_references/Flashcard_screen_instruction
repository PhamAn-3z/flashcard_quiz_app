III. THUẬT TOÁN CẮT CHUỖI TRÊN FLUTTER (FRONTEND LOGIC)
Để hỗ trợ đội Frontend viết mã nguồn, đây là hàm thuật toán Dart dùng để lắng nghe sự kiện thay đổi văn bản và chuyển đổi dữ liệu thô thành cục JSON đúng chuẩn:

Dart
Map<String, dynamic> parseRawTextToBulkPayload({
  required String rawText,
  required String cardDelimiter, // Ví dụ: "\n"
  required String termDelimiter, // Ví dụ: "\t"
  required String deckTitle,
  required String publicStatus,
  required int? parentId,
}) {
  // 1. Tách văn bản thô thành các dòng độc lập (mỗi dòng là một thẻ position)
  List<String> rawLines = rawText.split(cardDelimiter);

  // Dọn dẹp dòng trống rác do người dùng lỡ ấn Enter thừa ở cuối khung nhập
  rawLines.removeWhere((line) => line.trim().isEmpty);

  // 2. Định nghĩa cấu trúc headers ma trận cố định (Vì dạng dán chữ này chỉ có Thuật ngữ & Định nghĩa)
  List<Map<String, dynamic>> headers = [
    { "key": "term", "name": "Thuật ngữ", "position": 1 },
    { "key": "definition", "name": "Định nghĩa", "position": 2 }
  ];

  List<Map<String, String>> rows = [];

  // 3. Duyệt từng dòng để tách đôi lấy Cột 1 (Term) và Cột 2 (Definition)
  for (String line in rawLines) {
    List<String> parts = line.split(termDelimiter);

    if (parts.length >= 2) {
      String term = parts[0].trim();
      // Gom phần còn lại làm định nghĩa (đề phòng định nghĩa chứa ký tự trùng delimiter)
      String definition = parts.sublist(1).join(termDelimiter).trim();

      rows.add({
        "term": term,
        "definition": definition
      });
    }
  }

  // 4. Trả về cấu trúc Payload hoàn chỉnh cho API
  return {
    "deckTitle": deckTitle,
    "publicStatus": publicStatus,
    "parentId": parentId,
    "headers": headers,
    "rows": rows
  };
}
